FROM python:3.10.9

WORKDIR /app

# Копируем список зависимостей
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Копируем СОДЕРЖИМОЕ папки backend в текущую директорию (/app)
COPY backend/ .

EXPOSE 8000

# Убираем "backend/" из путей, так как manage.py уже лежит в /app/
CMD ["sh", "-c", "python backend/stripe_integration_tz/manage.py migrate && python stripe_integration_tz/manage.py runserver 0.0.0.0:8000"]